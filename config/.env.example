# Copy this file to .env and fill only the variables referenced by config.yaml.
# .env is ignored by git and loaded automatically by ./run.sh.

# Example agent key used when config.yaml has agent.api_key_env: TEST_AGENT_API_KEY
TEST_AGENT_API_KEY=

# Example judge key used when config.yaml has judge.api_key_env: TEST_JUDGE_API_KEY
TEST_JUDGE_API_KEY=

# Optional Alipay sandbox runtime input fields used when config.yaml has:
# runtime_inputs.alipay_sandbox.source: env
ALIPAY_APP_ID=
ALIPAY_SELLER_ID=
ALIPAY_GATEWAY=https://openapi-sandbox.dl.alipaydev.com/gateway.do
ALIPAY_MERCHANT_PRIVATE_KEY_PKCS8=
ALIPAY_MERCHANT_PRIVATE_KEY_PKCS1=
ALIPAY_PUBLIC_KEY=
ALIPAY_SANDBOX_BUYER_ACCOUNT=
ALIPAY_SANDBOX_BUYER_LOGIN_PASSWORD=
ALIPAY_SANDBOX_BUYER_PAY_PASSWORD=
ALIPAY_MINIAPP_APP_ID=
ALIPAY_OP_APP_ID=
